{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geobase-dsa-catalog-record-v3",
  "title": "Catalog record v3 — one published Tribal data-governance instrument (or a takedown tombstone)",
  "description": "Lanes write catalog.<lane>.jsonl. A record may not enter the merged catalog unless its manifest's effective clearance is 'cleared' (event-computed). review_state here is the initial state; human review upgrades happen via 'review' events. summary_path attaches via 'summary-attach' events. Tombstones (status=withdrawn) are produced only by the director takedown transaction.",
  "type": "object",
  "oneOf": [
    {
      "title": "Full record",
      "type": "object",
      "required": [
        "doc_id", "content_version", "parse_event", "title", "issuing_entity",
        "entity_type", "instrument_type", "legal_status", "covered_parties",
        "covered_data", "source_id", "source_url", "sha256", "local_path",
        "requirements", "tsdf_mapping", "review_state", "status"
      ],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
        "content_version": { "type": "string", "pattern": "^v[0-9]+-[a-f0-9]{8}$" },
        "parse_event": { "type": "string", "pattern": "^ev-[a-z0-9-]{8,64}$", "description": "FK → access-log parse event for this doc_id+content_version" },
        "title": { "type": "string" },
        "issuing_entity": { "type": "string" },
        "entity_type": { "enum": ["tribal-nation", "intertribal-org", "federal-agency", "state-agency", "academic", "ngo", "standards-body", "other"] },
        "nation_id": { "type": ["string", "null"], "description": "Canonical slug from sources/nations.json — tool-validated" },
        "region": { "type": ["string", "null"] },
        "atni_member": { "type": ["boolean", "null"] },
        "instrument_type": { "enum": ["constitution", "tribal-code", "resolution", "data-sharing-agreement", "dsa-template", "data-sovereignty-plan", "tribal-ip-law", "research-code", "research-permit", "irb-policy", "consent-policy", "data-governance-policy", "statute", "administrative-rule", "executive-order", "agency-policy", "mou-moa", "guidance", "presentation", "literature", "framework", "other"] },
        "legal_status": { "enum": ["enacted-current", "enacted-amended-check-version", "repealed-superseded", "pending", "draft", "template-only", "executed-agreement", "guidance-nonbinding", "scholarship-descriptive", "unknown-needs-review"] },
        "covered_parties": { "type": "string", "description": "Who the instrument binds. Literal 'unknown' forces review_state=needs-human-review (tool rule)." },
        "covered_data": { "type": "string", "description": "Data/activity scope. Literal 'unknown' forces review_state=needs-human-review (tool rule)." },
        "date_adopted": { "type": ["string", "null"] },
        "date_effective": { "type": ["string", "null"] },
        "date_amended_through": { "type": ["string", "null"] },
        "source_id": { "type": "string", "pattern": "^src-[a-z0-9-]{4,64}$" },
        "source_url": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "local_path": { "type": "string" },
        "license_or_terms": { "type": ["string", "null"] },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "oneOf": [
            {
              "description": "Instrument yields partner-facing requirements",
              "required": ["claims"],
              "properties": {
                "claims": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/claim" } },
                "none_reason": { "const": null }
              }
            },
            {
              "description": "Instrument yields none — say why",
              "required": ["none_reason"],
              "properties": {
                "claims": { "type": "array", "maxItems": 0 },
                "none_reason": { "type": "string", "minLength": 10 }
              }
            }
          ],
          "properties": {
            "claims": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
            "none_reason": { "type": ["string", "null"] }
          }
        },
        "tsdf_mapping": {
          "type": "object",
          "required": ["outcome"],
          "additionalProperties": false,
          "properties": {
            "outcome": { "$ref": "#/$defs/tsdf_outcome" },
            "closest_tiers": { "type": ["array", "null"], "items": { "enum": ["T0", "T1", "T2", "T3"] } },
            "notes": { "type": ["string", "null"] }
          }
        },
        "sensitivity_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["flag", "disposition"],
            "additionalProperties": false,
            "properties": {
              "flag": { "enum": ["personal-data", "signatures-contacts", "restricted-tk-references", "site-locations", "publication-ambiguous", "low-confidence-ocr", "other"] },
              "disposition": { "enum": ["pending-review", "cleared", "restricted", "removed"] },
              "notes": { "type": ["string", "null"] }
            }
          }
        },
        "review_state": { "enum": ["machine-extracted", "needs-human-review"], "description": "Initial state only — 'human-reviewed' is reachable solely via a human/* review event; the tool computes effective state" },
        "status": { "enum": ["cataloged", "needs-review", "superseded", "unverified"] },
        "notes": { "type": ["string", "null"] }
      }
    },
    {
      "title": "Takedown tombstone",
      "type": "object",
      "required": ["doc_id", "title", "issuing_entity", "status", "takedown_event", "notes"],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
        "title": { "type": "string" },
        "issuing_entity": { "type": "string" },
        "status": { "const": "withdrawn" },
        "takedown_event": { "type": "string", "pattern": "^ev-[a-z0-9-]{8,64}$" },
        "notes": { "type": "string", "description": "Reason + date; no requirements, paths, or hashes are retained" }
      }
    }
  ],
  "$defs": {
    "tsdf_outcome": { "enum": ["mapped", "partially-mapped", "not-represented", "in-tension", "not-applicable", "needs-human-review"] },
    "claim": {
      "type": "object",
      "required": ["claim_id", "category", "claim", "modal", "conditions", "cite"],
      "additionalProperties": false,
      "properties": {
        "claim_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}:c[0-9]+$" },
        "category": { "enum": ["consent-fpic", "review-board", "ip-tk-protection", "data-return-destruction", "ai-ml-restrictions", "publication-approval", "ownership-control", "redisclosure-limits", "benefit-sharing", "jurisdiction", "enforcement-remedies", "other"] },
        "claim": { "type": "string", "description": "Faithful statement preserving obligation strength, covered party, and scope" },
        "modal": { "enum": ["must-shall", "should-recommended", "may-permissive", "descriptive"] },
        "conditions": { "type": ["string", "null"], "description": "Qualifiers/exceptions/definitions — null only if genuinely unconditional" },
        "cite": { "type": "string", "description": "Section/page in the cited content_version" },
        "tsdf_outcome": { "anyOf": [{ "$ref": "#/$defs/tsdf_outcome" }, { "type": "null" }], "description": "Claim-level override when it differs from the record outcome" }
      }
    }
  }
}
